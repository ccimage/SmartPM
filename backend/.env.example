PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=smartpm
DB_PASSWORD=smartpm
DB_DATABASE=smartpm

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# NSQ
NSQ_HOST=localhost
NSQ_PORT=4150
NSQ_LOOKUPD_HTTP=http://localhost:4161
NSQ_NSQD_HOST=localhost
NSQ_NSQD_PORT=4150

# File Storage (RustFS / S3-compatible)
STORAGE_ENDPOINT=http://192.168.0.132:19000
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
STORAGE_BUCKET=smartpm
STORAGE_REGION=us-east-1

# AI
LLM_API_KEY=your-anthropic-api-key
LLM_MODEL=claude-sonnet-4-6
LLM_TIMEOUT_MS=30000
